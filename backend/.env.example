# Never commit a real token. Copy this file to .env and fill the value locally.
CSTCLOUD_API_KEY=your-cstcloud-token-here
CSTCLOUD_BASE_URL=https://uni-api.cstcloud.cn/v1
DATABASE_URL=sqlite:///./data/cstcloud_rag.db
CHROMA_PATH=./data/chroma
UPLOAD_PATH=./data/uploads
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
REQUEST_TIMEOUT=120
REQUEST_RETRIES=2
MAX_UPLOAD_MB=50
EMBEDDING_BATCH_SIZE=16
